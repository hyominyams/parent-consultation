generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserType {
  PARENT
  TEACHER
}

enum ConsultationType {
  PHONE
  IN_PERSON
}

enum SlotStatus {
  OPEN
  BLOCKED
  BOOKED
}

model ParentUser {
  id            String          @id @default(cuid())
  loginId       String          @unique
  grade         Int
  classroom     Int?
  studentNumber Int
  studentName   String
  parentName    String
  phone         String
  pinHash       String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  consents      ConsentRecord[]
  reservation   Reservation?
}

model TeacherUser {
  id           String                @id @default(cuid())
  grade        Int
  classroom    Int
  teacherName  String
  passwordHash String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  consents     ConsentRecord[]
  notifications TeacherNotification[]

  @@unique([grade, classroom])
}

model ConsentRecord {
  id                String       @id @default(cuid())
  userType          UserType
  parentUserId      String?
  teacherUserId     String?
  privacyConsent    Boolean
  thirdPartyConsent Boolean
  consentVersion    String
  consentedAt       DateTime     @default(now())
  parentUser        ParentUser?  @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  teacherUser       TeacherUser? @relation(fields: [teacherUserId], references: [id], onDelete: Cascade)

  @@index([userType, consentedAt])
}

model ClassScheduleConfig {
  id                  String            @id @default(cuid())
  grade               Int
  classroom           Int
  weekKey             String
  slotIntervalMinutes Int
  startTime           String
  endTime             String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  slots               ReservationSlot[]

  @@unique([grade, classroom, weekKey])
}

model ReservationSlot {
  id            String              @id @default(cuid())
  grade         Int
  classroom     Int
  weekKey       String
  date          DateTime
  timeLabel     String
  startDateTime DateTime
  endDateTime   DateTime
  status        SlotStatus          @default(OPEN)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  config        ClassScheduleConfig @relation(fields: [grade, classroom, weekKey], references: [grade, classroom, weekKey], onDelete: Cascade)
  reservation   Reservation?

  @@unique([grade, classroom, startDateTime])
  @@index([grade, classroom, weekKey, date])
}

model Reservation {
  id               String                @id @default(cuid())
  parentUserId     String                @unique
  slotId           String                @unique
  consultationType ConsultationType      @default(IN_PERSON)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  parentUser       ParentUser            @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  slot             ReservationSlot       @relation(fields: [slotId], references: [id], onDelete: Cascade)
  notifications TeacherNotification[]
}

model TeacherNotification {
  id           String      @id @default(cuid())
  teacherUserId String
  reservationId String?
  title        String
  message      String
  isRead       Boolean     @default(false)
  createdAt    DateTime    @default(now())
  teacherUser  TeacherUser @relation(fields: [teacherUserId], references: [id], onDelete: Cascade)
  reservation  Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([teacherUserId, isRead, createdAt])
}
